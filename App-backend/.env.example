PORT=5000
MONGO_URI=mongodb://localhost:27017/sentinel_iot
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
# Frontend URL (for verification links)
APP_WEB_URL=http://localhost:8080

# Registration policy (no domain restriction by default)

# Email sending (Gmail recommended with App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Sentinel <your_gmail@gmail.com>

# Alert notification
ALERT_EMAIL_TO=nadasaidani63@gmail.com
ALERT_EMAIL_COOLDOWN_MS=300000

# Data Centre 3 prototype bridge
ENABLE_PROTO_DATACENTER=true
PROTO_MONGO_URI=mongodb://username:password@host1:27017,host2:27017,host3:27017/sisedc_proto?ssl=true&authSource=admin&retryWrites=true&w=majority
PROTO_POLL_INTERVAL_MS=5000
PROTO_TOPOLOGY_REFRESH_MS=60000
PROTO_NODE_OFFLINE_AFTER_MS=120000
PROTO_DATACENTER_NAME=Data Centre 3 - Prototype
PROTO_DATACENTER_LOCATION=Prototype SISEDC, Tunis

# Email verification token expiry in minutes
EMAIL_VERIFY_EXPIRES_MIN=30
